# Supabase credentials for the shared "Add a book" feature.
# Copy this file to `.env.local` (gitignored) and fill in your project's values.
# Dashboard → Project Settings → API. Both values are public-safe (access is
# controlled by Row-Level Security), but keep the service_role key OUT of here.
#
# If these are unset, the app still runs read-only — the "Add book" button is
# hidden and only the static 10k dataset is shown.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
